# AMIS-DynaFlow local development environment example
# Copy this file to .env and edit values for your local machine.
# Do not commit real secrets to version control.

APP_ENV=development
LOG_LEVEL=INFO
RUN_ID_PREFIX=local

PROJECT_ROOT=.
DATA_DIR=data/sample
SCHEMA_DIR=data/schema
RESULTS_DIR=results/sample_outputs

# Placeholder values for future app-layer integration
DATABASE_URL=postgresql://user:password@localhost:5432/amis_dynaflow
REDIS_URL=redis://localhost:6379/0
